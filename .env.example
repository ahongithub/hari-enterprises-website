# ─────────────────────────────────────────────────────────────
# Hari Enterprises — Environment Variables
# Copy this file to `.env.local` and fill in the values.
# NEVER commit `.env.local`. Do not expose secrets to the browser
# (only NEXT_PUBLIC_* variables are sent to the client).
# ─────────────────────────────────────────────────────────────

# Public site URL (no trailing slash). Used for canonical URLs, sitemap, OG tags.
NEXT_PUBLIC_SITE_URL=https://www.harienterprises.co.in

# ── Email delivery (Resend — https://resend.com) ──
# If RESEND_API_KEY is not set, the enquiry form still validates and the UI
# shows a graceful "email us directly" fallback. Set these for live delivery.
RESEND_API_KEY=
# Where enquiries are delivered (defaults to jharidwari@gmail.com if unset)
ENQUIRY_TO=jharidwari@gmail.com
# Verified sender. Must be on a domain verified in Resend (e.g. enquiries@harienterprises.co.in).
# For quick testing you can use: Hari Enterprises <onboarding@resend.dev>
ENQUIRY_FROM=Hari Enterprises <enquiries@harienterprises.co.in>

# ── Analytics (all optional; nothing loads unless set) ──
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_CLARITY_ID=
